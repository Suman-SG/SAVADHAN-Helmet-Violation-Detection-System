# Gmail Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
FROM_EMAIL=Traffic Violation System <your-email@gmail.com>

# Web app security
SECRET_KEY=change-this-before-deploy
ADMIN_USERNAME=admin
ADMIN_PASSWORD=2006

# Email Sending
SEND_EMAIL=False
FAST_MODE=True
TEST_MODE=False

# Test Email
TEST_EMAIL=test@example.com

# Note: 
# 1. Generate Gmail App Password at: https://myaccount.google.com/apppasswords
# 2. Set SEND_EMAIL=True only after adding real credentials
# 3. Copy this file to .env and fill in your actual values
